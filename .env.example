# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# Fine-grained GitHub personal access token, scoped to public-repo read-only.
# Used by the GitHub issue search tool (M4) to query the fastapi/fastapi issue tracker
# with a higher rate limit than unauthenticated requests. No write scopes required.
GITHUB_TOKEN=

# LLM provider keys, consumed by the gateway layer (M2), not called directly.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LangSmith tracing (used from M2 onward for debugging, then production monitoring in M9).
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=fastapi-support-agent
